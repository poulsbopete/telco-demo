{
  "name": "telco-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"node server/dev-api.mjs\"",
    "dev:web": "vite",
    "dev:vercel": "vercel dev",
    "build": "vite build",
    "build:slides": "marp docs/public-launch-slides.md -o docs/index.html --html --allow-local-files --no-stdin",
    "lint": "eslint .",
    "preview": "vite preview",
    "bootstrap:workflow": "node scripts/bootstrap-kibana-workflow.mjs",
    "deploy:dashboard:observability": "node scripts/deploy-telco-dashboards.mjs observability",
    "deploy:dashboard:search": "node scripts/deploy-telco-dashboards.mjs search",
    "deploy:dashboard:security": "node scripts/deploy-telco-dashboards.mjs security"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@marp-team/marp-cli": "^4.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
