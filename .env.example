# Copy to .env.local for local dev, or set in Vercel → Project → Environment Variables.
# Use your own Elastic Cloud Serverless projects — never commit real keys.

# --- Required: Observability / Telemetry tab (ES|QL + health check) ---
ES_URL=https://YOUR-OBSERVABILITY-PROJECT.es.us-east-1.aws.elastic.cloud
ES_API_KEY=YOUR_BASE64_API_KEY_ID_AND_SECRET
KIBANA_URL=https://YOUR-OBSERVABILITY-PROJECT.kb.us-east-1.aws.elastic.cloud
VITE_KIBANA_URL=https://YOUR-OBSERVABILITY-PROJECT.kb.us-east-1.aws.elastic.cloud

# --- Optional: Kibana deep links (Search + Security tabs) ---
VITE_SEARCH_KIBANA_URL=https://YOUR-SEARCH-PROJECT.kb.us-east-1.aws.elastic.cloud
VITE_SECURITY_KIBANA_URL=https://YOUR-SECURITY-PROJECT.kb.us-east-1.aws.elastic.cloud

# --- Optional: Adaptive Networks tab (OTLP fault inject) ---
OTLP_ENDPOINT=https://YOUR-OBSERVABILITY-PROJECT.ingest.us-east-1.aws.elastic.cloud
# INCIDENT_WORKFLOW_ID=wf-xxxxxxxx
# DEMO_API_SECRET=choose-a-random-string-for-inject-auth

# --- Optional: deploy Security dashboard (scripts/deploy-telco-dashboards.mjs security) ---
# SECURITY_KIBANA_API_KEY=YOUR_SECURITY_KIBANA_API_KEY

# Aliases accepted by the API layer (either naming works)
# ELASTICSEARCH_URL=
# ELASTICSEARCH_API_KEY=

# --- Optional: password-gate /presenter/ guides (default password: elastic) ---
# PRESENTER_PASSWORD=elastic
# PRESENTER_AUTH_TOKEN=choose-a-random-session-token
